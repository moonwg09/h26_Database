
문제 23
Dept: 부서(depno NUMBER(2), dname VARCHAR(14), loc VARCHAR(13))
Emp : 사원(empno NUMBER(4), ename VARCHAR(10), job(업무) VARCHAR(9),
      mgr(팀장번호) NUMBER(4), hiredate DATE, sal NUMBER(7,2), 
      comm(커미션금액) NUMBER(7,2), deptno NUMBER(2))

(1)교재 질의 

⓵사원의 이름과 업무를 출력하시오. 단 사원의 이름은 ‘사원이름’, ‘업무는 ’사원업무‘, 머리글이 나오도록 출력하시오.
select ename as 사원이름, job as 사원업무
from emp;

⓶30번 부서에 근무하는 모든 사원의 이름과 급여를 출력하시오
select ename, sal
from emp
where deptno = 30;

⓷사원번호와 이름, 현재급여, 증가된 급여분(열 이름은  증가액), 10% 인상된 급여(열 이름은 ’인상된 급여‘)를 사원 번호 순으로 출력하시오.
select empno, ename, comm, (sal*0.1)
from emp
order by empno asc;


⓸’S’로 시작하는 모든 사원과 부서번호를 출력하시오.
select ename, deptno
from emp
where ename like 'S%';

⑤모든 사원의 최대 및 최소 급여, 합계 및 평균 급여를 출력하시오. 열이름은 각각 MAX,MIN, SUM, AVG로 한다. 단 소수점 이하는 반올림하여 정수로 출력한다.
select MAX(sal) as MAX, MIN(sal) as MIN, SUM(sal) as SUM, round(AVG(sal)) as AVG
from emp;

⓺업무(job)별로 동일한 업무를 하는 사원의 수를 출력하시오. 열이름은 각각 ‘업무’ 와 ‘업무별 사원수’로 한다.
select distinct e.job as 업무 ,(select count(e.empno) from emp e where e.job = e2.job) as 업무별 사원수
from emp e
join emp e2 on e.empno = e2.empno;


⓻사원의 최대 급여와 최소 급여의 차액을 출력하시오.
select Max(sal) - MIN(sal) as 차액
from emp;

⓼30번 부서의 사원 수와 사원들 급여의 합계와 평균을 출력하시오.
select count(empno), sum(sal), round(avg(sal))
from emp
where deptno = 30;

⓽평균 급여가 가장 높은 부서의 번호를 출력하시오.
select deptno, rount(AVG(sal)) as avg_sal
from emp
group by deptno
order by avg_sal desc
fetch first 1 rows only;



⓾세일즈맨(SALESMAN)을 제외하고, 각 업무별 사원의 총급여가 3,000이상인 가가 업무에 대
해서, 업무명과 각 업무별 평균 급여를 출력하시오.
select job, round(avg(sal))
from emp
group by job
having sum(sal) >= 3000 and job not in ('salesman');

⑪전체 사원 가운데 직속상관이 있는 사원의 수를 출력하시오.
select COUNT(*)
from emp e1
where exists (
    select 1 
    from emp e2 
    where e1.mgr = e2.empno
);

⑫EMP 테이블에서 이름, 급여, 커미션 금액(comm), 총액(sal*12+comm)을 구하여 총액이 많 !
은 순서대로 출력하시오.
select ename, sal, comm, (sal*12+comm) as sum_sal
from emp
order by sum_sal desc;


⑬부서별로 같은 업무를 하는 사람의 인원수를 구하여 부서번호, 업무 이름, 인원수를 출력하
시오.
select distinct deptno, job, (select count(e2.empno) from emp e2 where e.deptno = e2.deptno and e.job = e2.job) as 인원수
from emp e;

⑭사원이 한 명도 없는 부서의 이름을 출력하시오.
select d.dname
from dept d
where not exists(
    select e.empno
    from emp e
    where e.deptno = d.deptno
);

⑮같은 업무를 하는 사람의 수가 4명 이상인 업무와 인원수를 출력하시오.
select job, count(*) as count
from emp
group by job
having count(*) >= 4;

# GROUP BY job: 업무(job)가 같은 사람들끼리 바구니에 담는다고 생각하면 됩니다. (예: SALESMAN끼리, CLERK끼리)

